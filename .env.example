# ===================================================================
# ARCHIVO DE VARIABLES DE ENTORNO (.env)
# Copia este archivo como .env y completa los valores reales
# IMPORTANTE: NUNCA commitsear este archivo al repositorio
# ===================================================================

# ===================================================================
# BASE DE DATOS (PostgreSQL / Supabase)
# ===================================================================
# Ejemplo para Supabase:
# jdbc:postgresql://db.supabase.co:5432/postgres?sslmode=require
# Ejemplo para DigitalOcean Managed DB:
# jdbc:postgresql://private-db-xxxx-do-user-xxx.c.db.ondigitalocean.com:25060/vitalbite

DB_URL=jdbc:postgresql://localhost:5432/vitalbite_documental
DB_USERNAME=postgres
DB_PASSWORD=tu_contraseña_segura_aqui

# ===================================================================
# AWS S3 (Para almacenar PDFs y documentos)
# ===================================================================
AWS_BUCKET_NAME=vitalbite-uploads
AWS_REGION=us-east-2

# Credenciales IAM (crea un usuario IAM en AWS console)
# Asegúrate de darle permisos s3:GetObject, s3:PutObject, s3:DeleteObject
AWS_ACCESS_KEY=AKIA_______________________
AWS_SECRET_KEY=wJal_______________________

# ===================================================================
# JWT (Token de autenticación)
# Debe ser una string aleatoria de mínimo 32 caracteres
# Genera una con: openssl rand -base64 32
# ===================================================================
JWT_SECRET=tu_super_secret_jwt_muy_largo_y_aleatorio_aqui

# ===================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ===================================================================
# Para desarrollo local (puede ser 8082 o el puerto que prefieras)
SERVER_PORT=8082

# Para producción
SPRING_PROFILES_ACTIVE=production
LOG_LEVEL=INFO
